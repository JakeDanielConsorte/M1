import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        Passenger passenger = null;
        while(passenger == null){
            passenger = Passenger.checkStatus();
        }
        passenger = Passenger.fillUpRegistration(passenger);
        
        Route route = Route.selectRoute();
        Reservation reserve = new Reservation.ReservationBuilder().setPassenger(passenger).setRoute(route).build();
        
        Repository repo = new Repository.RepositoryBuilder().setDatabasePath().build();
        
        reserve.displaySummary();
        reserve.confirmReservation();
        repo.savePassenger(reserve);
        
        sc.close();
    }
}
