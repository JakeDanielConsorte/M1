import java.util.Random;
import java.util.Scanner;

public class Reservation {
    private final String RESERVATION_CODE;
    private final Passenger passenger;
    private final Route route;
    
    private Reservation(ReservationBuilder builder ){
        this.RESERVATION_CODE = generateReservationCode();
        this.passenger = builder.passenger;
        this.route = builder.route;
    }
    
    public void confirmReservation(){
        Scanner sc = new Scanner(System.in);
        int choice =0;
        
        System.out.println("Please confirm your reservation details to secure your train seat.");
        
         while(choice != 1){
                System.out.print("Press [1] to confirm reservation: ");
                
                if(sc.hasNextInt()){
                   choice = sc.nextInt();
                   
                   if(choice != 1){
                       System.out.println("Invalid input. Please press 1 to continue.");
                   }
                   
                } else {
                    System.out.println("Invalid input. Please press 1 to continue.");
                    sc.next();
                }
            }
         
        System.out.println("Reservation confirmed. Your reservation reference number is " + generateReservationCode());
        
    }     
    private String generateReservationCode(){
        Random rand = new Random();
        int num = rand.nextInt(100);
        return String.format("TK-%03d", num);
    }
     
     public void displaySummary(){
        Reservation reserve = new Reservation.ReservationBuilder().setPassenger(passenger).setRoute(route).build();
        reserve.getReservationCode();
        
        System.out.println("\n===== RESERVATION SUMMARY =====");
        System.out.println("Reservation Reference: " + reserve.getReservationCode());
        System.out.println("Name: " + reserve.getPassenger().getFullname());
        System.out.println("Category: " + reserve.getPassenger().getPassengerCategory());
        System.out.println("Discount: " + reserve.getPassenger().getDiscountRate());
        System.out.println("Origin: " + reserve.getRoute().getOriginStation());
        System.out.println("Destination: " + reserve.getRoute().getDestinationStation());
        System.out.println("Departure Time: " + reserve.getRoute().getDepartureTime());
     }
     
     public String getReservationCode(){ return RESERVATION_CODE;}
     public Passenger getPassenger(){ return passenger;}
     public Route getRoute(){ return route;}
    
    public static class ReservationBuilder{
        private String reservationCode;
        private Passenger passenger;
        private Route route;
        
        public ReservationBuilder setPassenger(Passenger passenger){
            this.passenger = passenger;
            return this;
        }
        
        public ReservationBuilder setRoute(Route route){
            this.route = route;
            return this;
        }
        
        public Reservation build(){
            return new Reservation(this);
        }
  }  
}



