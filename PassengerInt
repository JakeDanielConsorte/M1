import java.util.Scanner;

public class Passenger {
//attributes
    private final String PASSENGER_CATEGORY, FULLNAME, CONTACT_NUMBER;
    private final double DISCOUNT_RATE;
//constructor
    private Passenger(PassengerBuilder builder){
        this.PASSENGER_CATEGORY = builder.passengerCategory;
        this.DISCOUNT_RATE = builder.discountRate;
        this.FULLNAME = builder.fullname;
        this.CONTACT_NUMBER = builder.contactNumber;
    }
//getters
    public String getPassengerCategory(){return PASSENGER_CATEGORY;}
    public double getDiscountRate(){return DISCOUNT_RATE;}
    public String getFullname(){return FULLNAME;} 
    public String getContactNumber(){return CONTACT_NUMBER;}
    
//checkStatus Feature
     public static Passenger checkStatus() {
        Scanner sc = new Scanner(System.in);
        Passenger passenger = null;
        int choice;

        while (true) {
            System.out.println("Welcome! Please select your passenger category to see if you qualify for a fare discount:");
            System.out.println("[1] Regular");
            System.out.println("[2] Student");
            System.out.println("[3] Senior");
            System.out.println("[4] PWD");
            System.out.print("Enter choice (1-4): ");

            if (sc.hasNextInt()) {
                choice = sc.nextInt();
                sc.nextLine(); // consume newline

                String category;
                double discount;

                switch (choice) {
                    case 1 -> {category = "Regular"; discount = 0.0; }
                    case 2 -> { category = "Student"; discount = 0.20; }
                    case 3 -> { category = "Senior Citizen"; discount = 0.30; }
                    case 4 -> { category = "PWD"; discount = 0.25; }
                    default -> {
                        System.out.println("Invalid choice! Please enter 1-4.\n");
                        continue; // ask again
                    }
                }
                passenger = new PassengerBuilder()
                        .setPassengerCategory(category)
                        .setDiscountRate(discount)
                        .build();
                break; // valid selection
            } else {
                System.out.println("Invalid input! Please enter a number.\n");
                sc.next(); // consume invalid token
            }
        }
        System.out.println("Classification verified. The fare discount has been applied to your ticket.");
        
        int input = 0;
            while(input != 1){
                System.out.print("Press [1] to proceed to registration: ");
                if(sc.hasNextInt()){
                   input = sc.nextInt();
                   if(input != 1){
                       System.out.println("Invalid input. Please press 1 to continue.");
                   }
                } else {
                    System.out.println("Invalid input. Please press 1 to continue.");
                    sc.next();
                }
            }
        return passenger;
    }
     
    //PUT fillUpRegistration HERE
    public static Passenger fillUpRegistration(Passenger passenger){
        
        Scanner sc = new Scanner(System.in);
        
        System.out.println("Let's get you registered! Please enter your full name and contact details to secure your reservation.");
        
        String name, contact;
        
        while(true){
        System.out.print("Enter your Fullname: ");
        name = sc.nextLine();

        System.out.print("Enter your Contact Number: ");
        contact = sc.nextLine();

        if(Repository.passengerExists(name, contact)){
            System.out.println("Passenger already exists in the database.");
            System.out.println("Please enter a different name or contact number.\n");
        }else{
            break; // data is unique
        }
    }
        
        System.out.println("Registration successful! ");
         int choice = 0; //LOOPING
            while(choice != 1){
                System.out.print("Press [1] to proceed to select route: ");
                if(sc.hasNextInt()){
                   choice = sc.nextInt();
                   if(choice != 1){
                       System.out.println("Invalid input. Please press 1 to continue.");
                   }
                } else {
                    System.out.println("Invalid input. Please press 1 to continue.");
                    sc.next();
                }
            }
        
        return new PassengerBuilder()
                .setPassengerCategory(passenger.getPassengerCategory())
                .setDiscountRate(passenger.getDiscountRate())
                .setFullname(name)
                .setContactNumber(contact)
                .build();
    }

//Builder Pattern    
    public static class PassengerBuilder{

        private String passengerCategory, fullname, contactNumber;
        private double discountRate;

        public PassengerBuilder setPassengerCategory(String passengerCategory){
            this.passengerCategory = passengerCategory;
            return this;
        }

        public PassengerBuilder setDiscountRate(double discountRate){
            this.discountRate = discountRate;
            return this;
        }
        
        public PassengerBuilder setFullname(String fullname){
            this.fullname = fullname;
            return this;
        }
        
        public PassengerBuilder setContactNumber(String contactNumber){
            this.contactNumber = contactNumber;
            return this;
        }

        public Passenger build(){
            return new Passenger(this);
        }
    }
}
